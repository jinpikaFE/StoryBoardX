{
  "name": "server",
  "version": "1.0.0",
  "description": "JinPikaStoryboards Server - Nest.js Backend + LLM Service",
  "scripts": {
    "build": "nest build",
    "start": "cross-env APP_ENV=dev NODE_ENV=development nest start",
    "start:dev": "cross-env APP_ENV=dev NODE_ENV=development nest start --watch",
    "start:test": "cross-env APP_ENV=test NODE_ENV=test nest start --watch",
    "start:prod": "cross-env APP_ENV=prod NODE_ENV=production node dist/main"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "coze-coding-dev-sdk": "^0.7.17",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "cross-env": "^7.0.3",
    "typescript": "^5.6.0"
  }
}
